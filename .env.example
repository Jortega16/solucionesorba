# URL pública del sitio (metadatos y sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Correo visible en el sitio
NEXT_PUBLIC_CONTACT_EMAIL=jortega@solucionesorba.com

# Base de datos Postgres (CMS / backoffice)
# Local sin Docker: localhost | Con docker compose: el servicio web usa @db automáticamente
DATABASE_URL=postgresql://soluciones_orba:soluciones_orba@localhost:5432/soluciones_orba?schema=public
POSTGRES_DB=soluciones_orba
POSTGRES_USER=soluciones_orba
POSTGRES_PASSWORD=soluciones_orba
POSTGRES_PORT=5432

# Backoffice /admin
ADMIN_EMAIL=admin@solucionesorba.com
ADMIN_PASSWORD=cambia-esta-clave
ADMIN_SESSION_SECRET=cambia-este-secreto-largo-y-aleatorio

# Formulario de contacto (Resend: https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
CONTACT_FROM_EMAIL=contacto@solucionesorba.com
CONTACT_TO_EMAIL=jortega@solucionesorba.com
