generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model ContentPage {
  id          String        @id @default(cuid())
  slug        String
  locale      String        @default("es")
  status      ContentStatus @default(PUBLISHED)
  title       String
  description String
  eyebrow     String?
  heroTitle   String
  heroBody    String
  body        String        @default("")
  updatedAt   DateTime      @updatedAt
  createdAt   DateTime      @default(now())

  @@unique([slug, locale])
  @@index([locale, status])
}

model BlogPost {
  id          String        @id @default(cuid())
  slug        String
  locale      String        @default("es")
  status      ContentStatus @default(DRAFT)
  title       String
  description String
  category    String
  excerpt     String
  content     String
  publishedAt DateTime?
  updatedAt   DateTime      @updatedAt
  createdAt   DateTime      @default(now())

  @@unique([slug, locale])
  @@index([locale, status, publishedAt])
}
